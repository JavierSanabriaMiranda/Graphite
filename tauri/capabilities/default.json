{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:path:default",
    "core:event:default",
    "fs:allow-read",
    "fs:allow-read-file",
    "fs:allow-write",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$appData/attachments/**"
        }
      ]
    }
  ]
}